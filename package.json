{
  "name": "curium",
  "version": "0.6.0",
  "packageManager": "pnpm@11.11.0",
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node scripts/write-build-info.js && node scripts/sync-release-notes.js",
    "start": "node scripts/write-build-info.js && expo start",
    "android": "node scripts/write-build-info.js && expo start --android",
    "ios": "node scripts/write-build-info.js && expo start --ios",
    "web": "node scripts/write-build-info.js && expo start --web",
    "build:info": "node scripts/write-build-info.js",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/metro-runtime": "^57.0.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~57.0.7",
    "expo-build-properties": "^57.0.6",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.6",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image-manipulator": "~57.0.5",
    "expo-image-picker": "~57.0.5",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-media-library": "~57.0.3",
    "expo-navigation-bar": "^57.0.2",
    "expo-router": "~57.0.7",
    "expo-sharing": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "high-refresh-rate": "workspace:*",
    "phosphor-react-native": "^3.0.6",
    "qrcode": "1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-camera-tool": "^1.0.4",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-permissions": "^5.6.0",
    "react-native-qrcode-styled": "^0.4.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-view-shot": "5.1.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.16",
    "babel-preset-expo": "^57.0.3",
    "eslint": "^10.4.1",
    "eslint-config-expo": "^57.0.0",
    "expo-dev-client": "~57.0.7",
    "typescript": "~6.0.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": []
      }
    }
  }
}
