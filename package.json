{
  "name": "curium",
  "version": "0.5.6",
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node scripts/write-build-info.js && node scripts/sync-release-notes.js",
    "start": "node scripts/write-build-info.js && expo start",
    "android": "node scripts/write-build-info.js && expo start --android",
    "ios": "node scripts/write-build-info.js && expo start --ios",
    "web": "node scripts/write-build-info.js && expo start --web",
    "build:info": "node scripts/write-build-info.js",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/metro-runtime": "^56.0.15",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.12",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-image-manipulator": "~56.0.19",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-media-library": "~56.0.7",
    "expo-navigation-bar": "^56.0.3",
    "expo-router": "~56.2.11",
    "expo-sharing": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "qrcode": "1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-nitro-image": "^0.15.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-qrcode-styled": "^0.4.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-view-shot": "5.1.0",
    "react-native-vision-camera": "^5.0.11",
    "react-native-vision-camera-barcode-scanner": "^5.0.11",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.16",
    "babel-preset-expo": "^56.0.15",
    "eslint": "^10.4.1",
    "eslint-config-expo": "^56.0.4",
    "expo-dev-client": "~56.0.20",
    "typescript": "~6.0.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-nitro-image",
          "react-native-nitro-modules",
          "react-native-vision-camera-barcode-scanner"
        ]
      }
    }
  }
}
