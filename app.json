{
  "expo": {
    "name": "Curium",
    "slug": "Curium",
    "version": "0.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "curium",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.leviathnan.Curium",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0a"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Curium uses the camera to scan QR codes."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Curium saves QR codes to your photo library.",
          "savePhotosPermission": "Curium saves QR codes to your photo library."
        }
      ],
      "expo-sharing"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1373cef2-c4e3-47d9-a30f-f6fb52b4dabc"
      }
    }
  }
}
