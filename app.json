{
  "expo": {
    "name": "Curium",
    "slug": "Curium",
    "version": "0.5.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "curium",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Curium uses the camera to scan QR codes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "backgroundColor": "#0d0d0f",
      "predictiveBackGestureEnabled": false,
      "package": "com.nylxar.curium",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#f5f0e8",
          "dark": {
            "image": "./assets/icon.png",
            "backgroundColor": "#0d0d0f"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Curium saves QR codes to your photo library.",
          "savePhotosPermission": "Curium saves QR codes to your photo library.",
          "granularPermissions": ["photo"]
        }
      ],
      [
        "expo-image-picker",
        {
          "microphonePermission": false
        }
      ],
      "expo-sharing",
      "expo-system-ui",
      [
        "expo-navigation-bar",
        {
          "style": "light",
          "enforceContrast": false
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1373cef2-c4e3-47d9-a30f-f6fb52b4dabc"
      }
    }
  }
}
